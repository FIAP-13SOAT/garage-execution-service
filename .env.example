# Application
PORT=3000
NODE_ENV=development

# AWS (LocalStack for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# DynamoDB
DYNAMODB_ENDPOINT=http://localhost:4566

# SQS
SQS_ENDPOINT=http://localhost:4566
SQS_EXECUTION_COMMANDS_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/garage-execution-commands
SQS_EXECUTION_REPLIES_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/garage-execution-replies
SQS_EXECUTION_EVENTS_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/garage-execution-events
SQS_STOCK_COMMANDS_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/garage-stock-commands
SQS_STOCK_REPLIES_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/garage-stock-replies

# Datadog
DD_API_KEY=your_api_key_here
DD_APP_KEY=your_app_key_here
DD_SERVICE=garage-execution-service
DD_ENV=development
DD_VERSION=1.0.0
DD_AGENT_HOST=localhost
DD_TRACE_ENABLED=false
